{
  "$schema": "https://dl.viam.dev/module.schema.json",
  "module_id": "erh:viam-chess",
  "visibility": "public",
  "url": "https://github.com/erh/viam-chess",
  "description": "chess",
  "models": [
    {
      "api": "rdk:service:generic",
      "model": "erh:viam-chess:chess",
      "short_description": "Provide a short (100 characters or less) description of this model here",
      "markdown_link": "README.md#chess-config"
    },
    {
      "api": "rdk:service:vision",
      "model": "erh:viam-chess:piece-finder",
      "short_description": "debugging tool mostly i think",
      "markdown_link": "README.md#piece-finder-config"
    }

  ],
  "applications": [
    {
      "name": "chess-control",
      "type": "single_machine",
      "entrypoint": "dist/index.html",
      "logoPath": "static/logo.png",
      "customizations": {
        "machinePicker": {
          "heading": "Chess Robot Control",
          "subheading": "Select your chess robot to start playing"
        }
      }
    }
  ],
  "markdown_link": "README.md",
  "entrypoint": "bin/viam-chess",
  "first_run": "",
  "build": {
    "build": "make module.tar.gz",
    "setup": "make setup",
    "path": "module.tar.gz",
    "arch": [
      "linux/amd64",
      "linux/arm64",
      "darwin/arm64"
    ]
  }
}
